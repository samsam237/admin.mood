{
  "name": "mood-dashboard",
  "version": "1.0.0",
  "description": "Dashboard admin MOOD - collecte et affichage des données",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "init-db": "node server/init-db.js",
    "backup": "node server/run-backup.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
